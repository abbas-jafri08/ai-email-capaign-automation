# Optional: enables the "Generate with AI" button (drafts subject + body via Groq)
GROQ_API_KEY=your_api_key_here
GROQ_MODEL=your_api_key_model_here

# Port for the local server (default 3000). Not used on Vercel.
PORT=3000

# REQUIRED for "opened" tracking to work: the publicly reachable URL of this
# server. Each sent email embeds a 1x1 tracking pixel pointing at
# <PUBLIC_BASE_URL>/api/track/<token>.gif — recipients' mail clients load it,
# which marks that recipient "opened". If this is unset, the app falls back
# to the incoming request's host. On Vercel that fallback actually resolves
# to your real deployed domain, so it will work — but set this explicitly to
# your PRODUCTION domain (not a preview-deployment URL) so pixel links in
# already-sent emails don't break the next time you redeploy.
#   - Local testing: run `ngrok http 3000` and paste the https URL it gives you
#   - Vercel: e.g. https://your-project.vercel.app or your custom domain
PUBLIC_BASE_URL=

# REQUIRED on Vercel (and recommended everywhere): a free Upstash Redis
# database, used to store campaigns/opens so ALL serverless instances see the
# same data. Without this, each serverless invocation gets its own empty
# memory and "opened" tracking can never work reliably in production — this
# is the actual bug behind opens not registering once deployed.
#   1. Create a free database at https://console.upstash.com (or add the
#      "Upstash" integration from the Vercel Marketplace to your project)
#   2. Copy the REST URL and REST token it gives you into these two vars
#      (in Vercel: Project Settings -> Environment Variables)
# If left blank, the app falls back to in-memory storage — fine for local
# testing on your own machine, NOT fine once deployed.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NOTE: SMTP credentials are entered directly in the web UI (not stored here),
# since different campaigns may use different sending accounts.
# Common SMTP examples:
#   Gmail:      smtp.gmail.com  port 587  (use an "App Password", not your normal password)
#   Outlook:    smtp.office365.com  port 587
#   SendGrid:   smtp.sendgrid.net  port 587  (user = "apikey", pass = your SendGrid API key)
#   Mailgun:    smtp.mailgun.org  port 587
